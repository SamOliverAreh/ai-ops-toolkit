# ── General ──────────────────────────────────────────────
ENV=development                        # development | staging | production
LOG_LEVEL=INFO

# ── Paths ─────────────────────────────────────────────────
MODEL_ARTIFACT_DIR=/opt/models
BACKUP_DEST=s3://your-bucket/model-backups   # or gs:// for GCS
LOG_DIR=/var/log/ai-ops

# ── Notifications ─────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
SLACK_CHANNEL=#ops-alerts

SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
ALERT_EMAIL_FROM=ops@yourdomain.com
ALERT_EMAIL_TO=team@yourdomain.com

# ── Jira ──────────────────────────────────────────────────
JIRA_SERVER=https://yourorg.atlassian.net
JIRA_USER=your@email.com
JIRA_API_TOKEN=your_jira_token
JIRA_PROJECT_KEY=OPS

# ── Database / Data Sources ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ops_db
DB_USER=ops_user
DB_PASSWORD=changeme

# ── Model Monitoring ──────────────────────────────────────
MODEL_ENDPOINT=http://localhost:8080/predict
DRIFT_THRESHOLD=0.15
PERFORMANCE_THRESHOLD=0.80

# ── Prometheus ────────────────────────────────────────────
PROMETHEUS_PORT=9090
METRICS_PORT=8000

# ── Docker Registry ───────────────────────────────────────
DOCKER_REGISTRY=ghcr.io/YOUR_USERNAME
IMAGE_NAME=ai-ops-toolkit
